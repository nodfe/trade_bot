# Database
DATABASE_URL=postgresql+asyncpg://tradebot:tradebot@localhost:5432/tradebot
DATABASE_SYNC_URL=postgresql://tradebot:tradebot@localhost:5432/tradebot

# Redis
REDIS_URL=redis://localhost:6379/0

# Tushare Pro
TUSHARE_TOKEN=your_tushare_token_here

# AKShare (no token needed)
# AKSHARE is free, no configuration required

# Feishu Bot
FEISHU_APP_ID=your_feishu_app_id
FEISHU_APP_SECRET=your_feishu_app_secret
FEISHU_VERIFICATION_TOKEN=your_verification_token
FEISHU_ENCRYPT_KEY=your_encrypt_key

# App
APP_ENV=development
APP_SECRET_KEY=your-secret-key-change-in-production
APP_DEBUG=true

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
